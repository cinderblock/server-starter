{
  "name": "server-starter",
  "version": "2.0.0",
  "description": "Start a node server on a TCP port or unix socket. Handles stale socket files and applies socketMode/socketOwner after listening.",
  "type": "module",
  "main": "dist/server-starter.js",
  "types": "dist/server-starter.d.ts",
  "exports": {
    ".": {
      "types": "./dist/server-starter.d.ts",
      "default": "./dist/server-starter.js"
    }
  },
  "files": [
    "dist/server-starter.js",
    "dist/server-starter.js.map",
    "dist/server-starter.d.ts",
    "dist/server-starter.d.ts.map"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "test": "npm run build && node --test dist/server-starter.test.js",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cinderblock/server-starter.git"
  },
  "keywords": [
    "server",
    "start",
    "listen",
    "unix-socket",
    "tcp",
    "chmod",
    "chown",
    "stale-socket"
  ],
  "author": "Cameron Tacklind <cameron@tacklind.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/cinderblock/server-starter/issues"
  },
  "homepage": "https://github.com/cinderblock/server-starter#readme",
  "optionalDependencies": {
    "userid": "^1.2.5"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "typescript": "^6.0.3"
  }
}
